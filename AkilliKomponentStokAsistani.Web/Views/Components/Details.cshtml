@model AkilliKomponentStokAsistani.Web.Models.ComponentItem
@{
    ViewData["Title"] = "Component Details";
}

<h1>Component Details</h1>

<div>
    <h4>ComponentItem</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Component Name</dt>
        <dd class="col-sm-10">@Model.ComponentName</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>

        <dt class="col-sm-2">Package Type</dt>
        <dd class="col-sm-10">@Model.PackageType</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>

        <dt class="col-sm-2">Stock Quantity</dt>
        <dd class="col-sm-10">@Model.StockQuantity</dd>

        <dt class="col-sm-2">Minimum Stock Level</dt>
        <dd class="col-sm-10">@Model.MinimumStockLevel</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Datasheet URL</dt>
        <dd class="col-sm-10">
            <a href="@Model.DatasheetUrl" target="_blank">@Model.DatasheetUrl</a>
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Düzenle</a>
    <a asp-action="Index" class="btn btn-secondary">Geri Dön</a>
</div>