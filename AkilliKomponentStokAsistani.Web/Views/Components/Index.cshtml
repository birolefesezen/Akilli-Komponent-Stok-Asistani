@model AkilliKomponentStokAsistani.Web.ViewModels.ComponentIndexViewModel
@{
    ViewData["Title"] = "Components";
}

<h1>Components</h1>

<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Komponent Ara" />
        </div>
        <div class="col-md-4">
            <select name="category" class="form-select">
                @if (string.IsNullOrEmpty(Model.SelectedCategory))
                {
                    <option value="" selected>Tüm Kategoriler</option>
                }
                else
                {
                    <option value="">Tüm Kategoriler</option>
                }

                @foreach (var category in Model.Categories)
                {
                    if (Model.SelectedCategory == category)
                    {
                        <option value="@category" selected>@category</option>
                    }
                    else
                    {
                        <option value="@category">@category</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check">
                <input type="checkbox" name="showOnlyCritical" class="form-check-input" id="showOnlyCritical" @(Model.ShowOnlyCritical ? "checked" : "") />
                <label class="form-check-label" for="showOnlyCritical">Sadece Kritik Stok</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a href="/Components" class="btn btn-secondary">Temizle</a>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Component Name</th>
            <th>Category</th>
            <th>Package Type</th>
            <th>Price</th>
            <th>Stock Quantity</th>
            <th>Minimum Stock Level</th>
            <th>Stok Durumu</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Components)
        {
            <tr>
                <td>@item.ComponentName</td>
                <td>@item.Category</td>
                <td>@item.PackageType</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.StockQuantity</td>
                <td>@item.MinimumStockLevel</td>
                <td>
                    @if (item.IsCriticalStock)
                    {
                        <span class="badge bg-danger">Kritik Stok</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Yeterli Stok</span>
                    }
                </td>
                <td>
                    <a class="btn btn-info" asp-action="Details" asp-route-id="@item.Id">Detaylar</a>
                    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>